<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PracticeAPI — Free REST API for Beginners</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  
  <!-- Icon Library (Lucide) -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* CSS Variables for Light & Dark Mode */
    :root {
      /* Light Mode Colors */
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --primary: #6366f1;
      --primary-light: #e0e7ff;
      --secondary: #f1f5f9;
      --border: #e2e8f0;
      
      /* Method Colors - Light */
      --get-bg: #d1fae5; --get-text: #059669;
      --post-bg: #e0e7ff; --post-text: #4f46e5;
      --put-bg: #fef3c7; --put-text: #d97706;
      --del-bg: #ffe4e6; --del-text: #e11d48;

      --sans: 'Plus Jakarta Sans', sans-serif;
      --mono: 'JetBrains Mono', monospace;
      
      --nav-bg: rgba(255, 255, 255, 0.8);
    }

    /* Dark Mode Overrides */
    body.dark-mode {
      --bg: #0f172a;
      --card: #1e293b;
      --text: #f8fafc;
      --muted: #94a3b8;
      --primary: #818cf8;
      --primary-light: rgba(99, 102, 241, 0.2);
      --secondary: #334155;
      --border: #334155;
      
      --nav-bg: rgba(15, 23, 42, 0.85);

      /* Adjusting method colors for dark mode visibility */
      --get-bg: rgba(16, 185, 129, 0.2); --get-text: #34d399;
      --post-bg: rgba(99, 102, 241, 0.2); --post-text: #818cf8;
      --put-bg: rgba(245, 158, 11, 0.2); --put-text: #fbbf24;
      --del-bg: rgba(244, 63, 94, 0.2); --del-text: #fb7185;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; height: 70px;
      background: var(--nav-bg);
      backdrop-filter: blur(12px);
      border-bottom: 2px solid var(--border);
      transition: background-color 0.3s ease, border-color 0.3s ease;
    }
    .nav-logo {
      font-size: 18px; font-weight: 800; letter-spacing: -0.02em;
      color: var(--text); text-decoration: none;
      display: flex; align-items: center; gap: 8px;
    }
    .nav-logo svg { color: var(--primary); animation: float 3s ease-in-out infinite; }
    
    .nav-links { display: flex; gap: 24px; list-style: none; font-weight: 600; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 14px; transition: color .2s; }
    .nav-links a:hover { color: var(--primary); }
    
    .nav-right { display: flex; gap: 10px; align-items: center; }
    
    .btn-icon {
      background: var(--secondary); border: none; border-radius: 12px;
      width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
      color: var(--text); cursor: pointer; transition: all 0.2s;
    }
    .btn-icon:hover { background: var(--primary-light); color: var(--primary); transform: translateY(-2px); }

    .btn-ghost {
      padding: 8px 16px; border-radius: 12px; border: 2px solid var(--border);
      color: var(--text); font-family: var(--sans); font-size: 14px; font-weight: 600;
      background: var(--card); cursor: pointer; text-decoration: none;
      transition: all .2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-ghost:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); transform: translateY(-2px); }
    
    .btn-primary {
      padding: 8px 18px; border-radius: 12px; border: none;
      background: var(--primary); color: white; font-weight: 600;
      font-family: var(--sans); font-size: 14px; cursor: pointer;
      text-decoration: none; display: inline-flex; align-items: center; gap: 6px; 
      transition: all .2s; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4); opacity: 0.9; }

    /* ── HERO ── */
    .hero {
      text-align: center; padding: 80px 1.5rem 60px;
      max-width: 860px; margin: 0 auto;
    }
    .hero-icon-container {
      width: 72px; height: 72px; background: var(--primary-light); border-radius: 20px;
      display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;
      color: var(--primary); animation: float 3s ease-in-out infinite;
    }
    .hero h1 {
      font-weight: 800; font-size: clamp(32px, 6vw, 64px);
      line-height: 1.1; letter-spacing: -0.03em;
      color: var(--text); margin-bottom: 20px;
    }
    .hero h1 em {
      font-style: normal; color: var(--primary); position: relative; display: inline-block;
    }
    .hero h1 em::after {
      content: ''; position: absolute; bottom: 4px; left: 0; right: 0;
      height: 8px; background: var(--primary-light); z-index: -1;
      border-radius: 4px; transform: rotate(-1deg);
    }
    .hero p {
      margin: 0 auto; max-width: 520px;
      color: var(--muted); font-size: 16px; line-height: 1.7;
    }
    .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 36px; }
    
    .base-url-pill {
      display: inline-flex; align-items: center; gap: 12px;
      margin: 48px auto 0; padding: 12px 24px; border-radius: 16px;
      border: 2px dashed var(--border); background: var(--card);
      font-size: 14px; color: var(--muted); font-family: var(--mono);
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05); flex-wrap: wrap; justify-content: center;
    }
    .base-url-pill code { color: var(--primary); font-weight: 600; word-break: break-all; }
    .copy-btn {
      background: var(--secondary); border: 1px solid var(--border); cursor: pointer;
      color: var(--text); font-size: 12px; padding: 6px 12px; font-weight: 600;
      border-radius: 8px; font-family: var(--sans); transition: all .2s; display: flex; gap: 6px; align-items: center;
    }
    .copy-btn:hover { background: var(--primary-light); color: var(--primary); border-color: var(--primary); }

    /* ── SECTIONS ── */
    .section { max-width: 1100px; margin: 0 auto; padding: 80px 1.5rem; }
    .section-label {
      font-size: 12px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase;
      color: var(--primary); margin-bottom: 12px; display: flex; align-items: center; gap: 6px;
    }
    .section-title { font-weight: 800; font-size: clamp(26px, 4vw, 42px); line-height: 1.2; color: var(--text); margin-bottom: 16px; }
    .section-sub { color: var(--muted); font-size: 15px; max-width: 500px; line-height: 1.7; margin-bottom: 48px; }

    /* ── CATEGORIES ── */
    .categories-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;
    }
    .cat-card {
      border: 2px solid var(--border); border-radius: 20px; padding: 16px 20px; 
      background: var(--card); display: flex; align-items: center; gap: 16px;
      transition: all 0.2s; cursor: default; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    }
    .cat-card:hover { border-color: var(--primary); transform: translateY(-4px); box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.15); }
    .cat-icon {
      width: 48px; height: 48px; border-radius: 14px; color: var(--muted);
      background: var(--secondary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.2s;
    }
    .cat-card:hover .cat-icon { background: var(--primary-light); color: var(--primary); animation: float 2s ease-in-out infinite; }
    .cat-name { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 2px; }
    .cat-route { font-size: 12px; font-family: var(--mono); color: var(--muted); }
    .cat-route span { color: var(--primary); font-weight: 600; }

    /* ── ENDPOINTS ── */
    .endpoints-grid { display: grid; gap: 12px; }
    .endpoint-row {
      display: grid; grid-template-columns: 100px 1fr 1fr; align-items: center; 
      background: var(--card); padding: 16px 24px; border-radius: 16px; 
      border: 2px solid var(--border); transition: all .2s; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    }
    .endpoint-row:hover { border-color: var(--primary); transform: translateX(4px); }
    .endpoint-row.header { background: transparent; border: none; box-shadow: none; padding-bottom: 0; font-size: 12px; font-weight: 800; text-transform: uppercase; color: var(--muted); }
    .endpoint-row.header:hover { transform: none; }
    .method { font-weight: 800; font-family: var(--mono); font-size: 12px; padding: 4px 10px; border-radius: 8px; display: inline-block; width: fit-content; text-align: center; }
    .GET { background: var(--get-bg); color: var(--get-text); }
    .POST { background: var(--post-bg); color: var(--post-text); }
    .PUT { background: var(--put-bg); color: var(--put-text); }
    .DELETE { background: var(--del-bg); color: var(--del-text); }
    .endpoint-path { font-size: 14px; font-family: var(--mono); font-weight: 600; color: var(--text); word-break: break-all; }
    .endpoint-path span { color: var(--primary); background: var(--primary-light); padding: 2px 6px; border-radius: 6px; }
    .endpoint-desc { font-size: 14px; color: var(--muted); }

    /* ── CODE DEMOS ── */
    .demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .code-card { 
      border: 2px solid var(--border); border-radius: 20px; overflow: hidden; 
      background: #1e293b; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
    }
    .code-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px; background: #0f172a; border-bottom: 1px solid #334155;
    }
    .code-header .dots { display: flex; gap: 8px; }
    .code-header .dots span { width: 12px; height: 12px; border-radius: 50%; }
    .d1{background:#ff5f57} .d2{background:#febb2c} .d3{background:#28c940}
    .code-title { font-size: 13px; font-weight: 600; color: #94a3b8; font-family: var(--sans); }
    .code-lang  { font-size: 12px; font-weight: 600; color: #818cf8; background: rgba(99, 102, 241, 0.2); padding: 2px 8px; border-radius: 6px; }
    pre { padding: 20px; font-family: var(--mono); font-size: 13px; line-height: 1.6; overflow-x: auto; color: #f8fafc; margin: 0; }
    .kw{color:#c792ea} .fn{color:#82aaff} .str{color:#c3e88d} .num{color:#f78c6c} .cmt{color:#64748b; font-style:italic} .key{color:#7dd3fc}

    /* ── FEATURES ── */
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
    .feature-card {
      border: 2px solid var(--border); border-radius: 20px; padding: 32px 24px; 
      background: var(--card); position: relative; transition: all .2s; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    }
    .feature-card:hover { border-color: var(--primary); transform: translateY(-4px); box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.1); }
    .feature-icon-box {
      width: 56px; height: 56px; border-radius: 16px; background: var(--secondary); color: var(--muted);
      display: flex; align-items: center; justify-content: center; margin-bottom: 20px; transition: all 0.2s;
    }
    .feature-card:hover .feature-icon-box { background: var(--primary-light); color: var(--primary); animation: float 2s ease-in-out infinite; }
    .feature-title { font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
    .feature-desc  { font-size: 14px; color: var(--muted); line-height: 1.6; }

    /* ── INSTALL ── */
    .install-box { border: 2px solid var(--border); border-radius: 20px; overflow: hidden; background: #1e293b; max-width: 600px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
    .install-box .ib-header { display: flex; align-items: center; gap: 8px; padding: 14px 20px; background: #0f172a; font-size: 13px; font-weight: 600; color: #94a3b8; border-bottom: 1px solid #334155; }
    .ti { color: #34d399; }
    .tools-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 20px; }
    .tool-chip {
      padding: 8px 16px; border-radius: 12px; border: 2px solid var(--border); font-weight: 600;
      background: var(--card); color: var(--muted); font-size: 14px; transition: all .2s; cursor: default;
    }
    .tool-chip:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); transform: translateY(-2px); }

    hr.divider { border: none; border-top: 2px dashed var(--border); margin: 0 1.5rem; }

    /* ── FOOTER ── */
    footer { border-top: 2px solid var(--border); padding: 40px 2rem; background: var(--card); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
    footer .fl { font-size: 14px; font-weight: 600; color: var(--muted); }
    footer a { color: var(--primary); text-decoration: none; }
    footer a:hover { text-decoration: underline; }
/* ── MOBILE RESPONSIVENESS ── */
    @media (max-width: 768px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; /* Hidden on mobile to save space */ }
      /* .btn-ghost span wali line yaha se hata di gayi hai */
      
      .hero { padding: 60px 1rem 40px; }
      .base-url-pill { flex-direction: column; text-align: center; }
      
      .endpoint-row { grid-template-columns: 1fr; gap: 8px; padding: 16px; align-items: start; }
      .endpoint-row.header { display: none; }
      
      .demo-grid { grid-template-columns: 1fr; }
      
      footer { flex-direction: column; text-align: center; justify-content: center; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">
    <i data-lucide="rocket"></i> PracticeAPI
  </a>
  <ul class="nav-links">
    <li><a href="#categories">Categories</a></li>
    <li><a href="#endpoints">Endpoints</a></li>
    <li><a href="#examples">Examples</a></li>
  </ul>
  <div class="nav-right">
    <button id="theme-toggle" class="btn-icon" aria-label="Toggle Dark Mode">
      <i data-lucide="moon" id="theme-icon"></i>
    </button>
    <a class="btn-ghost" href="https://github.com/git-shubham-side/PracticeAPI" target="_blank">
      <i data-lucide="github"></i> <span>GitHub</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-icon-container">
    <i data-lucide="blocks" style="width: 40px; height: 40px;"></i>
  </div>
  <h1>A REST API built for <br/><em>real practice</em></h1>
  <p>
    Stop reading about APIs. Start calling them. PracticeAPI gives you clean endpoints,
    real JSON, and proper error codes — across 20+ data categories so you never run out of things to build.
  </p>
  <div class="hero-actions">
    <a class="btn-primary" style="padding: 12px 24px; font-size: 15px;" href="#quickstart">
      <i data-lucide="download"></i> Clone & Run
    </a>
    <a class="btn-ghost" style="padding: 12px 24px; font-size: 15px;" href="#categories">
      Browse Categories
    </a>
  </div>
  <div class="base-url-pill">
    <span>Base URL</span>
    <code>http://localhost:3000/api/v1</code>
    <button class="copy-btn" onclick="copyBase()">
      <i data-lucide="copy" style="width: 14px; height: 14px;"></i> Copy
    </button>
  </div>
</section>

<!-- CATEGORIES -->
<section class="section" id="categories">
  <p class="section-label"><i data-lucide="layers" style="width:16px;"></i> Data Categories</p>
  <h2 class="section-title">20+ categories. Endless things to build.</h2>
  <p class="section-sub">
    Every category returns realistic, structured JSON — ready to plug into your frontend,
    test your error handling, or practice any HTTP method.
  </p>

  <div class="categories-grid">
    <!-- EJS Template Loop for Categories (Replaced Emojis with Lucide Icon names) -->
    <% const cats = [
      { icon: 'user', name: 'Person', slug: 'person' },
      { icon: 'map-pin', name: 'Location', slug: 'location' },
      { icon: 'calendar', name: 'Date', slug: 'date' },
      { icon: 'circle-dollar-sign', name: 'Finance', slug: 'finance' },
      { icon: 'shopping-cart', name: 'Commerce', slug: 'commerce' },
      { icon: 'globe', name: 'Localization', slug: 'localization' },
      { icon: 'plane', name: 'Airline', slug: 'airline' },
      { icon: 'paw-print', name: 'Animal', slug: 'animal' },
      { icon: 'book', name: 'Book', slug: 'book' },
      { icon: 'palette', name: 'Color', slug: 'color' },
      { icon: 'building', name: 'Company', slug: 'company' },
      { icon: 'database', name: 'Database', slug: 'database' },
      { icon: 'pizza', name: 'Food', slug: 'food' },
      { icon: 'image', name: 'Images', slug: 'images' },
      { icon: 'file-text', name: 'Lorem', slug: 'lorem' },
      { icon: 'music', name: 'Music', slug: 'music' },
      { icon: 'smartphone', name: 'Phones', slug: 'phones' },
      { icon: 'microscope', name: 'Science', slug: 'science' },
      { icon: 'car', name: 'Vehicle', slug: 'vehicle' },
      { icon: 'message-square', name: 'Words', slug: 'words' }
    ]; %>
    <% cats.forEach(cat => { %>
    <div class="cat-card">
      <div class="cat-icon">
        <i data-lucide="<%= cat.icon %>"></i>
      </div>
      <div>
        <div class="cat-name"><%= cat.name %></div>
        <div class="cat-route">/api/v1/<span><%= cat.slug %></span></div>
      </div>
    </div>
    <% }); %>
  </div>
</section>

<hr class="divider" />

<!-- ENDPOINTS -->
<section class="section" id="endpoints">
  <p class="section-label"><i data-lucide="route" style="width:16px;"></i> Routes</p>
  <h2 class="section-title">Full CRUD. Every category.</h2>
  <p class="section-sub">
    Each category supports the same five routes — learn one, know them all.
  </p>
  <div class="endpoints-grid">
    <div class="endpoint-row header">
      <div>Method</div><div>Route</div><div>Description</div>
    </div>
    <div class="endpoint-row">
      <div><span class="method GET">GET</span></div>
      <div class="endpoint-path">/:category</div>
      <div class="endpoint-desc">Fetch all records</div>
    </div>
    <div class="endpoint-row">
      <div><span class="method GET">GET</span></div>
      <div class="endpoint-path">/:category/<span>:id</span></div>
      <div class="endpoint-desc">Fetch single record by ID</div>
    </div>
    <div class="endpoint-row">
      <div><span class="method POST">POST</span></div>
      <div class="endpoint-path">/:category</div>
      <div class="endpoint-desc">Create a new record</div>
    </div>
    <div class="endpoint-row">
      <div><span class="method PUT">PUT</span></div>
      <div class="endpoint-path">/:category/<span>:id</span></div>
      <div class="endpoint-desc">Update an existing record</div>
    </div>
    <div class="endpoint-row">
      <div><span class="method DELETE">DELETE</span></div>
      <div class="endpoint-path">/:category/<span>:id</span></div>
      <div class="endpoint-desc">Delete a record</div>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- EXAMPLES -->
<section class="section" id="examples">
  <p class="section-label"><i data-lucide="code" style="width:16px;"></i> Examples</p>
  <h2 class="section-title">Request → Response.</h2>
  <p class="section-sub">Clean JSON in, clean JSON out. Same pattern across every category.</p>

  <div class="demo-grid">
    <div class="code-card">
      <div class="code-header">
        <div class="dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div>
        <div class="code-title">GET /person/1</div>
        <div class="code-lang">json</div>
      </div>
      <pre>{
  <span class="key">"id"</span>:        <span class="num">1</span>,
  <span class="key">"name"</span>:      <span class="str">"Riya Sharma"</span>,
  <span class="key">"email"</span>:     <span class="str">"riya@example.com"</span>,
  <span class="key">"role"</span>:      <span class="str">"user"</span>,
  <span class="key">"createdAt"</span>: <span class="str">"2024-01-15T10:30:00Z"</span>
}</pre>
    </div>

    <div class="code-card">
      <div class="code-header">
        <div class="dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div>
        <div class="code-title">Axios · Fetch Books</div>
        <div class="code-lang">js</div>
      </div>
      <pre><span class="kw">const</span> res = <span class="kw">await</span> <span class="fn">axios</span>.<span class="fn">get</span>(
  <span class="str">'/api/v1/book'</span>
);
<span class="cmt">// res.data → array of books</span>
<span class="cmt">// res.status → 200 OK</span>
<span class="fn">console</span>.<span class="fn">log</span>(res.data[<span class="num">0</span>].title);</pre>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- FEATURES -->
<section class="section">
  <p class="section-label"><i data-lucide="zap" style="width:16px;"></i> Why PracticeAPI</p>
  <h2 class="section-title">Built to teach real habits.</h2>
  <p class="section-sub">Most practice APIs are fake. This one behaves exactly like production.</p>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon-box"><i data-lucide="zap" style="width:28px;height:28px;"></i></div>
      <div class="feature-title">Zero Friction</div>
      <div class="feature-desc">No API keys. No OAuth. Clone and start hitting endpoints in 60 seconds flat.</div>
    </div>
    <div class="feature-card">
