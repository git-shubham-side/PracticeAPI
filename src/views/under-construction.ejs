<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- EJS variable for title, default to 'Under Construction' if not provided -->
    <title>Under Construction — PracticeAPI</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <!-- Icon Library (Lucide) -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* CSS Variables for Light & Dark Mode */
      :root {
        --bg: #f8fafc;
        --card: #ffffff;
        --text: #1e293b;
        --muted: #64748b;
        --primary: #6366f1;
        --primary-light: #e0e7ff;
        --secondary: #f1f5f9;
        --border: #e2e8f0;

        --sans: "Plus Jakarta Sans", sans-serif;
        --mono: "JetBrains Mono", monospace;

        --nav-bg: rgba(255, 255, 255, 0.8);
      }

      body.dark-mode {
        --bg: #0f172a;
        --card: #1e293b;
        --text: #f8fafc;
        --muted: #94a3b8;
        --primary: #818cf8;
        --primary-light: rgba(99, 102, 241, 0.2);
        --secondary: #334155;
        --border: #334155;
        --nav-bg: rgba(15, 23, 42, 0.85);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        font-size: 15px;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        transition:
          background-color 0.3s ease,
          color 0.3s ease;
      }

      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-10px);
        }
      }

      @keyframes spin-slow {
        100% {
          transform: rotate(360deg);
        }
      }

      /* ── NAV ── */
      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        height: 70px;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        border-bottom: 2px solid var(--border);
        transition:
          background-color 0.3s ease,
          border-color 0.3s ease;
      }
      .nav-logo {
        font-size: 18px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--text);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .nav-logo svg {
        color: var(--primary);
      }

      .nav-right {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .btn-icon {
        background: var(--secondary);
        border: none;
        border-radius: 12px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text);
        cursor: pointer;
        transition: all 0.2s;
      }
      .btn-icon:hover {
        background: var(--primary-light);
        color: var(--primary);
        transform: translateY(-2px);
      }

      .btn-ghost {
        padding: 8px 16px;
        border-radius: 12px;
        border: 2px solid var(--border);
        color: var(--text);
        font-family: var(--sans);
        font-size: 14px;
        font-weight: 600;
        background: var(--card);
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .btn-ghost:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--primary-light);
        transform: translateY(-2px);
      }

      .btn-primary {
        padding: 12px 24px;
        border-radius: 12px;
        border: none;
        background: var(--primary);
        color: white;
        font-weight: 600;
        font-family: var(--sans);
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
        opacity: 0.9;
      }

      /* ── HERO (Centered Content) ── */
      .hero {
        text-align: center;
        padding: 100px 1.5rem 60px;
        max-width: 860px;
        margin: auto; /* Centers the section vertically and horizontally */
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      .hero-icon-container {
        width: 80px;
        height: 80px;
        background: var(--primary-light);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 32px;
        color: var(--primary);
        animation: float 3s ease-in-out infinite;
        box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.15);
      }
      .hero-icon-container svg {
        animation: spin-slow 8s linear infinite;
      }

      .hero h1 {
        font-weight: 800;
        font-size: clamp(32px, 6vw, 64px);
        line-height: 1.1;
        letter-spacing: -0.03em;
        color: var(--text);
        margin-bottom: 20px;
      }
      .hero h1 em {
        font-style: normal;
        color: var(--primary);
        position: relative;
        display: inline-block;
      }
      .hero h1 em::after {
        content: "";
        position: absolute;
        bottom: 4px;
        left: 0;
        right: 0;
        height: 8px;
        background: var(--primary-light);
        z-index: -1;
        border-radius: 4px;
        transform: rotate(-1deg);
      }
      .hero p {
        margin: 0 auto 36px;
        max-width: 520px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.7;
      }

      .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 10px 20px;
        border-radius: 100px;
        border: 2px dashed var(--border);
        background: var(--card);
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
        font-family: var(--mono);
        margin-bottom: 36px;
      }
      .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #f59e0b; /* Amber/Warning color */
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.2);
        animation: pulse 2s infinite;
      }

      @keyframes pulse {
        0% {
          box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4);
        }
        70% {
          box-shadow: 0 0 0 6px rgba(245, 158, 11, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(245, 158, 11, 0);
        }
      }

      /* ── FOOTER ── */
      footer {
        border-top: 2px solid var(--border);
        padding: 30px 2rem;
        background: var(--card);
        text-align: center;
      }
      footer .fl {
        font-size: 14px;
        font-weight: 600;
        color: var(--muted);
      }

      /* ── MOBILE RESPONSIVENESS ── */
      @media (max-width: 768px) {
        nav {
          padding: 0 1.5rem;
        }
        .hero {
          padding: 60px 1rem 40px;
        }
        .btn-ghost span {
          display: none;
        } /* Kept text hidden here for nav button consistency on mobile */
      }
    </style>
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <a class="nav-logo" href="/">
        <i data-lucide="rocket"></i> PracticeAPI
      </a>
      <div class="nav-right">
        <button
          id="theme-toggle"
          class="btn-icon"
          aria-label="Toggle Dark Mode"
        >
          <i data-lucide="moon" id="theme-icon"></i>
        </button>
      </div>
    </nav>

    <!-- HERO / CONSTRUCTION SECTION -->
    <section class="hero">
      <div class="hero-icon-container">
        <i data-lucide="settings" style="width: 40px; height: 40px"></i>
      </div>

      <div class="status-pill">
        <div class="status-dot"></div>
        <span>Status: Work In Progress</span>
      </div>
      <div class="status-pill">
        <!-- <div class="status-dot"></div> -->
        <span>route: <%= route %> ── Will be Available Soon!</span>
      </div>

      <h1>Page Under <br /><em>Construction</em></h1>

      <p>
        We're currently building some awesome new features for this route. Grab
        a coffee and check back in a little while!
      </p>

      <div
        style="
          display: flex;
          gap: 16px;
          flex-wrap: wrap;
          justify-content: center;
        "
      >
        <a class="btn-primary" href="/">
          <i data-lucide="arrow-left"></i> Back to Home
        </a>
        <a
          class="btn-ghost"
          href="https://github.com/git-shubham-side/PracticeAPI"
          target="_blank"
        >
          <i data-lucide="github"></i> <span>Report Issue</span>
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="fl">Built for beginners by @git-shubham-side</div>
    </footer>

    <script>
      // Initialize Lucide Icons
      lucide.createIcons();

      // Dark Mode Toggle Logic (Same as your main page)
      const themeToggle = document.getElementById("theme-toggle");
      const themeIcon = document.getElementById("theme-icon");

      const currentTheme = localStorage.getItem("theme");
      if (currentTheme === "dark") {
        document.body.classList.add("dark-mode");
        themeIcon.setAttribute("data-lucide", "sun");
      }

      themeToggle.addEventListener("click", () => {
        document.body.classList.toggle("dark-mode");

        if (document.body.classList.contains("dark-mode")) {
          themeIcon.setAttribute("data-lucide", "sun");
          localStorage.setItem("theme", "dark");
        } else {
          themeIcon.setAttribute("data-lucide", "moon");
          localStorage.setItem("theme", "light");
        }
        lucide.createIcons();
      });
    </script>
  </body>
</html>
