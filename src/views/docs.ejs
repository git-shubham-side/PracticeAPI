            <td><code>/images</code></td>
            <td>Get image data</td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- CODE EXAMPLES -->
    <section class="doc-section" id="examples">
      <h2><i data-lucide="code" style="width: 28px; margin-right: 8px; vertical-align: -2px;"></i> Code Examples</h2>

      <h3>JavaScript - Fetch API</h3>
      <p>Simple GET request to fetch person data:</p>
      <div class="code-block">
        <div class="code-header">JavaScript</div>
        <button class="copy-code-btn"><i data-lucide="copy" style="width:14px;height:14px;"></i> Copy</button>
        <pre><span class="kw">fetch</span>(<span class="str">'https://practiceapi.up.railway.app/api/v1/person'</span>)
  .<span class="fn">then</span>(<span class="fn">response</span> => <span class="fn">response</span>.<span class="fn">json</span>())
  .<span class="fn">then</span>(<span class="fn">data</span> => <span class="fn">console</span>.<span class="fn">log</span>(<span class="fn">data</span>))
  .<span class="fn">catch</span>(<span class="fn">error</span> => <span class="fn">console</span>.<span class="fn">error</span>(<span class="str">'Error:'</span>, <span class="fn">error</span>));</pre>
      </div>

      <h3>JavaScript - Async/Await</h3>
      <p>Modern approach using async/await:</p>
      <div class="code-block">
        <div class="code-header">JavaScript</div>
