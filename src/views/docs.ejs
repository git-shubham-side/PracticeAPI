</nav>

<!-- MAIN -->
<div class="docs-container">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h3><i data-lucide="book-open" style="width: 14px; margin-bottom: 4px;"></i> Table of Contents</h3>
    <ul>
      <li><a href="#intro">Introduction</a></li>
      <li><a href="#baseurl">Base URL</a></li>
      <li><a href="#auth">Authentication</a></li>
      <li><a href="#making-requests">Making Requests</a></li>
