<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Documentation — PracticeAPI</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  
  <!-- Lucide Icons -->
  <script defer src="https://unpkg.com/lucide@0.511.0/dist/umd/lucide.min.js"></script>

  <script>
    window.addEventListener("DOMContentLoaded", () => {
      lucide.createIcons();

      // Theme Toggle
      const themeToggle = document.getElementById("theme-toggle");
      const themeIcon = document.getElementById("theme-icon");
      
      const currentTheme = localStorage.getItem("theme");
      if (currentTheme === "dark") {
        document.body.classList.add("dark-mode");
        themeIcon.setAttribute("data-lucide", "sun");
      } else {
        themeIcon.setAttribute("data-lucide", "moon");
      }

      lucide.createIcons();

      themeToggle.addEventListener("click", () => {
        document.body.classList.toggle("dark-mode");
        if (document.body.classList.contains("dark-mode")) {
          localStorage.setItem("theme", "dark");
          themeIcon.setAttribute("data-lucide", "sun");
        } else {
          localStorage.setItem("theme", "light");
          themeIcon.setAttribute("data-lucide", "moon");
        }
        lucide.createIcons();
      });

      // Copy code blocks
      document.querySelectorAll(".copy-code-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const codeBlock = btn.nextElementSibling;
          const code = codeBlock.innerText;
          navigator.clipboard.writeText(code).then(() => {
            btn.innerHTML = '<i data-lucide="check" style="width:14px;height:14px;"></i> Copied!';
            btn.style.background = "var(--get-bg)";
            btn.style.color = "var(--get-text)";
            lucide.createIcons();
            setTimeout(() => {
              btn.innerHTML = '<i data-lucide="copy" style="width:14px;height:14px;"></i> Copy';
              btn.style.background = "";
              btn.style.color = "";
              lucide.createIcons();
            }, 2000);
          });
        });
      });

      // Smooth scroll for navigation
      document.querySelectorAll("a[href^='#']").forEach((anchor) => {
        anchor.addEventListener("click", function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute("href"));
          if (target) {
            target.scrollIntoView({ behavior: "smooth" });
          }
        });
      });
    });
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --primary: #6366f1;
      --primary-light: #e0e7ff;
      --secondary: #f1f5f9;
      --border: #e2e8f0;
      
      --get-bg: #d1fae5; --get-text: #059669;
      --post-bg: #e0e7ff; --post-text: #4f46e5;
      --put-bg: #fef3c7; --put-text: #d97706;
      --del-bg: #ffe4e6; --del-text: #e11d48;

      --sans: 'Plus Jakarta Sans', sans-serif;
      --mono: 'JetBrains Mono', monospace;
    }

    body.dark-mode {
      --bg: #0f172a;
      --card: #1e293b;
      --text: #f8fafc;
      --muted: #94a3b8;
      --primary: #818cf8;
      --primary-light: rgba(99, 102, 241, 0.2);
      --secondary: #334155;
      --border: #334155;
      
      --get-bg: rgba(16, 185, 129, 0.2); --get-text: #34d399;
      --post-bg: rgba(99, 102, 241, 0.2); --post-text: #818cf8;
      --put-bg: rgba(245, 158, 11, 0.2); --put-text: #fbbf24;
      --del-bg: rgba(244, 63, 94, 0.2); --del-text: #fb7185;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; height: 70px;
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      border-bottom: 2px solid var(--border);
      transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode nav {
      background: rgba(15, 23, 42, 0.85);
    }

    .nav-logo {
      font-size: 18px; font-weight: 800; letter-spacing: -0.02em;
      color: var(--text); text-decoration: none;
      display: flex; align-items: center; gap: 8px;
    }
    
    .nav-links { display: flex; gap: 30px; list-style: none; font-weight: 600; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 14px; transition: color .2s; }
    .nav-links a:hover { color: var(--primary); }
    
    .nav-right { display: flex; gap: 10px; align-items: center; }
    
    .btn-icon {
      background: var(--secondary); border: none; border-radius: 12px;
      width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
      color: var(--text); cursor: pointer; transition: all 0.2s;
    }
    .btn-icon:hover { background: var(--primary-light); color: var(--primary); }

    .btn-ghost {
      padding: 8px 16px; border-radius: 12px; border: 2px solid var(--border);
      color: var(--text); font-family: var(--sans); font-size: 14px; font-weight: 600;
      background: var(--card); cursor: pointer; text-decoration: none;
      transition: all .2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-ghost:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }

    /* LAYOUT */
    .docs-container {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 40px;
      max-width: 1400px;
      margin: 0 auto;
      padding: 40px 2rem;
    }

    /* SIDEBAR */
    .sidebar {
      position: sticky;
      top: 90px;
      height: fit-content;
      border: 2px solid var(--border);
      border-radius: 16px;
      padding: 24px;
      background: var(--card);
    }

    .sidebar h3 {
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--primary);
      margin-bottom: 16px;
    }

    .sidebar ul {
      list-style: none;
    }

    .sidebar ul li {
      margin-bottom: 12px;
    }

    .sidebar ul li a {
      color: var(--muted);
      text-decoration: none;
      font-size: 14px;
      transition: all 0.2s;
      display: block;
      padding: 8px 12px;
      border-radius: 8px;
    }

    .sidebar ul li a:hover {
      color: var(--primary);
      background: var(--primary-light);
    }

    /* CONTENT */
    .docs-content {
      max-width: 800px;
    }

    .doc-section {
      margin-bottom: 60px;
    }

    .doc-section h2 {
      font-size: 32px;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 3px solid var(--primary);
      display: inline-block;
    }

    .doc-section h3 {
      font-size: 20px;
      font-weight: 800;
      color: var(--text);
      margin-top: 32px;
      margin-bottom: 12px;
    }

    .doc-section p {
      color: var(--muted);
      line-height: 1.8;
      margin-bottom: 16px;
    }

    .doc-section ul {
      list-style: none;
      margin-bottom: 24px;
    }

    .doc-section ul li {
      color: var(--muted);
      margin-bottom: 10px;
      padding-left: 24px;
      position: relative;
    }

    .doc-section ul li:before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--primary);
      font-weight: bold;
    }

    /* CODE BLOCK */
    .code-block {
      background: #1e293b;
      border: 2px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin: 24px 0;
      position: relative;
    }

    .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 20px;
      background: #0f172a;
      border-bottom: 1px solid #334155;
      font-size: 12px;
      color: #94a3b8;
      font-weight: 600;
    }

    .copy-code-btn {
      background: var(--secondary);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      font-family: var(--sans);
      display: flex;
      gap: 6px;
      align-items: center;
      transition: all 0.2s;
    }

    .copy-code-btn:hover {
      background: var(--primary-light);
      color: var(--primary);
      border-color: var(--primary);
    }

    pre {
      padding: 20px;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.6;
      overflow-x: auto;
      color: #f8fafc;
      margin: 0;
    }

    .kw { color: #c792ea; }
    .fn { color: #82aaff; }
    .str { color: #c3e88d; }
    .num { color: #f78c6c; }
    .key { color: #7dd3fc; }

    /* RESPONSE EXAMPLE */
    .response-example {
      background: var(--card);
      border: 2px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      margin: 24px 0;
    }

    .response-label {
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 12px;
      letter-spacing: 0.1em;
    }

    /* METHOD BADGES */
    .method {
      font-weight: 800;
      font-family: var(--mono);
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 6px;
      display: inline-block;
      text-align: center;
    }

    .GET { background: var(--get-bg); color: var(--get-text); }
    .POST { background: var(--post-bg); color: var(--post-text); }
    .PUT { background: var(--put-bg); color: var(--put-text); }
    .DELETE { background: var(--del-bg); color: var(--del-text); }

    /* TABLE */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 24px 0;
      border: 2px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }

    thead {
      background: var(--secondary);
    }

    th {
      padding: 12px 16px;
      text-align: left;
      font-weight: 800;
      color: var(--text);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    td {
      padding: 12px 16px;
      color: var(--muted);
      font-size: 14px;
      border-top: 1px solid var(--border);
    }

    td code {
      background: var(--secondary);
      padding: 4px 8px;
      border-radius: 4px;
      color: var(--primary);
      font-family: var(--mono);
      font-weight: 600;
    }

    /* ALERT BOX */
    .info-box {
      background: var(--primary-light);
      border-left: 4px solid var(--primary);
      border-radius: 8px;
      padding: 16px;
      margin: 24px 0;
      color: var(--text);
    }

    .info-box strong {
      color: var(--primary);
    }

    /* MOBILE */
    @media (max-width: 768px) {
      nav { padding: 0 1rem; }
      .nav-links { display: none; }
      
      .docs-container {
        grid-template-columns: 1fr;
        gap: 24px;
        padding: 20px 1rem;
      }

      .sidebar {
        position: static;
        border: none;
        padding: 0;
      }

      .sidebar ul {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .doc-section h2 {
        font-size: 24px;
      }

      pre {
        font-size: 11px;
        overflow-x: auto;
      }
    }
  </style>
</head>
